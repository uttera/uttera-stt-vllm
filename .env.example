# -----------------------------------------------------------------------------
# Uttera STT vLLM — example environment
# Copy to .env and tweak for your deployment.
# -----------------------------------------------------------------------------

# Enable verbose logging (stats, stack traces).
DEBUG=false

# Network
HOST=0.0.0.0
PORT=9005

# -----------------------------------------------------------------------------
# Model
# -----------------------------------------------------------------------------

# HuggingFace model ID. Default: Whisper-large-v3-turbo.
WHISPER_MODEL=openai/whisper-large-v3-turbo

# Name advertised through /v1/models and in OpenAI-compatible responses.
SERVED_MODEL_NAME=whisper-1

# -----------------------------------------------------------------------------
# vLLM engine tuning
# Defaults validated on RTX 5090 (32 GB). Reduce VLLM_MAX_NUM_SEQS and/or
# VLLM_GPU_MEM_UTIL on smaller GPUs.
# -----------------------------------------------------------------------------

VLLM_DTYPE=float16
VLLM_GPU_MEM_UTIL=0.9
VLLM_MAX_NUM_SEQS=64
VLLM_MAX_MODEL_LEN=448

# Skip CUDA graph compilation at startup. Useful for rapid iteration;
# leave disabled in production for best latency.
VLLM_ENFORCE_EAGER=false

# -----------------------------------------------------------------------------
# Routing telemetry
# -----------------------------------------------------------------------------

# Drain-time (seconds) at which load_score saturates to 1.0 and the node
# stops accepting requests. Matches uttera-stt-hotcold so the upstream
# router can use a single threshold across the fleet.
ROUTING_DRAIN_CAP_SECONDS=120

# -----------------------------------------------------------------------------
# Optional: LibreTranslate for /v1/audio/translations
# When set, /v1/audio/translations transcribes with Whisper and then posts the
# text to a LibreTranslate instance to reach the requested `to_language`.
# If LIBRETRANSLATE_URL is empty, /v1/audio/translations returns HTTP 501.
# Needed because openai/whisper-large-v3-turbo (the default) does not support
# the native `translate` task. LibreTranslate also enables targets other than
# English, which Whisper's own translate does not.
# -----------------------------------------------------------------------------

LIBRETRANSLATE_URL=
LIBRETRANSLATE_API_KEY=
LIBRETRANSLATE_TIMEOUT_S=30

# -----------------------------------------------------------------------------
# Optional: Redis self-registration for upstream router discovery
# Leave REDIS_URL empty to disable.
# -----------------------------------------------------------------------------

REDIS_URL=
# NODE_ID defaults to {NODE_HOST}:{NODE_PORT}
NODE_ID=
NODE_HOST=localhost
NODE_PORT=9005
REDIS_PUBLISH_INTERVAL=0.5

# -----------------------------------------------------------------------------
# Asset cache (models, Whisper feature-extractors, etc.)
# Defaults to ./assets/models/huggingface if unset.
# -----------------------------------------------------------------------------

# XDG_CACHE_HOME=/path/to/assets/models
